<local:MyCard Margin="0,0,0,12" Title="欢迎使用" CanSwap="True" IsSwaped="False">
     <StackPanel Margin="24,40,24,18">

          <Image Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,10"
                 Source="https://pcl2.api.mgcraft.net/1080x1080%E6%97%A0%E8%83%8C%E6%99%AF.png"/>

          <TextBlock HorizontalAlignment="Center" Margin="0,0,0,6"
                     Foreground="{DynamicResource ColorBrush2}"
                     FontSize="24" FontWeight="Bold"
                     Text="芒果方块基础优化整合包" />

          <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,14"
                     Foreground="{DynamicResource ColorBrush2}"
                     FontSize="13"
                     Text="更稳定 · 更流畅 · 更适合中文玩家的 Minecraft 基础体验" />

          <local:MyHint Margin="0,0,0,8" Padding="10,6,10,6" IsWarn="True"
                        Text="作者：芒果方块　｜　当前版本：3.8-1.21.5　｜　最新版本：3.9-26.2" />

          <local:MyHint Margin="0,0,0,14" Padding="10,6,10,6" IsWarn="True"
                        Text="该版本已过期，请及时更新至最新版本 3.9-26.2。建议优先使用整合包内推荐的游戏版本、Java 与启动参数。如果遇到异常，可先查看更新日志或前往反馈区提交问题。" />

          <Grid Margin="0,2,0,0">
               <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="1*" />
               </Grid.ColumnDefinitions>

               <local:MyButton Grid.Column="0" Height="35"
                               Text="查看更新日志"
                               EventType="打开网页"
                               EventData="https://space.bilibili.com/23240466/dynamic"
                               ToolTip="查看整合包更新记录与公告" />

               <local:MyButton Grid.Column="2" Height="35"
                               Text="反馈问题 / 建议"
                               EventType="打开网页"
                               EventData="https://space.bilibili.com/23240466/dynamic"
                               ToolTip="遇到问题可在此反馈" />
          </Grid>

     </StackPanel>
</local:MyCard>


