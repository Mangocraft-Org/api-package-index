<local:MyCard Margin="0,0,0,12" Title="关于芒果方块" CanSwap="True" IsSwaped="False">
     <StackPanel Margin="24,40,24,18">

          <Image Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,10"
                 Source="https://pcl2.api.mgcraft.net/1080x1080%E6%97%A0%E8%83%8C%E6%99%AF.png"/>

          <TextBlock HorizontalAlignment="Center" Margin="0,0,0,4"
                     Foreground="{DynamicResource ColorBrush2}"
                     FontSize="20" FontWeight="Bold"
                     Text="芒果方块团队" />

          <TextBlock HorizontalAlignment="Center" Margin="0,0,0,14"
                     Foreground="{DynamicResource ColorBrush2}"
                     FontSize="13"
                     Text="与你，共同发现" />

          <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                     Text="芒果方块团队成立于 2016 年 1 月 1 日，是一个以 Minecraft 内容创作为核心的团队。" />

          <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                     Text="我们长期创作 Minecraft 教程、整合包、纪录片《This is My Minecraft》等内容，并持续探索更适合中文玩家的游戏体验。" />

          <TextBlock TextWrapping="Wrap" Margin="0,0,0,14"
                     Text="同时，芒果方块也在运营大型公益项目「芒果方块粉丝服」，主张打造不破坏原版玩法、长期稳定运行、玩家共同建设的 Minecraft 服务器。" />

          <local:MyHint Margin="0,0,0,14" Padding="10,6,10,6" IsWarn="False"
                        Text="感谢每一位使用整合包、观看视频、参与服务器建设的朋友。你的支持，是我们继续更新下去的最大动力。" />

          <local:MyButton Margin="0,0,0,0" Height="35"
                          Text="点击了解更多"
                          EventType="打开网页"
                          EventData="https://www.mgcraft.net/about"
                          ToolTip="进入芒果方块关于页面" />

     </StackPanel>
</local:MyCard>
